# === LLM API ===
OPENAI_API_KEY=sk-your-api-key-here

# The following have defaults, usually no need to change
# OPENAI_API_BASE=https://api.deepseek.com
# LLM_MODEL=deepseek-v4-flash

# === Embedding API ===
# Any OpenAI-compatible embedding API works (DeepSeek, OpenAI, DashScope, etc.)
EMBEDDING_API_KEY=sk-your-embedding-key
EMBEDDING_API_BASE=https://api.deepseek.com
EMBEDDING_MODEL=deepseek-embedding

# === Optional ===
# LANGSMITH_API_KEY=your-langsmith-key
# LANGSMITH_PROJECT=Agent

# === Advanced (defaults are fine) ===
# DATABASE_URL=sqlite+aiosqlite:///./data/arxiv_tracker.db
# CHROMA_PERSIST_DIR=./data/vectors
# ARXIV_MAX_RESULTS=50
# DAILY_FETCH_HOUR=8
# DAILY_FETCH_MINUTE=0
